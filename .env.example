# ===========================================
# Reflect Forward - 環境変数テンプレート
# ===========================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# 注意: 実際の値は .env に設定し、.env は Git にコミットしないでください
# ===========================================

# ----- Database -----
# ローカル開発: Docker PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reflect_forward

# 本番環境: Supabase (実際の値に置き換える)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ----- JWT -----
# 本番環境では必ず強力なランダム文字列に置き換えること
# 生成例: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:3001
