# ===========================================
# Reflect Forward - 環境変数テンプレート
# ===========================================
# このファイルをコピーして .env を作成してください
# cp .env.example .env
#
# 注意: 実際の値は .env に設定し、.env は Git にコミットしないでください
# ===========================================

# ----- Database -----
# ローカル開発: Docker PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reflect_forward
# Prisma Accelerate 経由で CF Workers から接続するための直接接続 URL（マイグレーション用）
# ローカルでは DATABASE_URL と同じ値で可（本番では Supabase 直接接続文字列を設定する）
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reflect_forward

# 本番環境:
# DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=...
# DIRECT_DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# ----- JWT -----
# 本番環境では必ず強力なランダム文字列に置き換えること
# 生成例: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ----- API Server -----
PORT=3001

# CORS: 本番環境ではフロントエンドのオリジンを設定すること
# 例: CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:3001

# ----- MCP Servers -----
# GitHub Personal Access Token (必要なスコープ: repo, read:org, read:user)
# 生成: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
